# ============================================================
# LINKEDIN NURTURE SYSTEM — ENVIRONMENT VARIABLES
# Copy this to .env and fill in your values
# See docs/SETUP.md for where to get each value
# ============================================================

# ---- ANTHROPIC (Claude API) --------------------------------
# Get from: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-YOUR_KEY_HERE

# ---- HEYREACH ---------------------------------------------
# Get from: HeyReach dashboard → Integrations → API Key
HEYREACH_API_KEY=YOUR_HEYREACH_API_KEY

# ---- SERVER -----------------------------------------------
PORT=3000
NODE_ENV=development

# Webhook secret — set any random string, use same value in HeyReach webhook config
WEBHOOK_SECRET=your-random-webhook-secret-here

# ---- OPTIONAL: GOOGLE SHEETS (for lead tracking) ----------
# Get from: Google Cloud Console → Service Accounts
# Leave blank to use in-memory store for now
GOOGLE_SHEETS_ID=
GOOGLE_SERVICE_ACCOUNT_EMAIL=
GOOGLE_PRIVATE_KEY=

# ---- OPTIONAL: AIRTABLE (alternative to Sheets) ----------
AIRTABLE_API_KEY=
AIRTABLE_BASE_ID=
AIRTABLE_TABLE_NAME=leads

# ---- OPTIONAL: SLACK NOTIFICATIONS (human review alerts) --
# Create an Incoming Webhook: https://api.slack.com/messaging/webhooks
# Leave blank to disable Slack notifications.
SLACK_WEBHOOK_URL=
# Public dashboard URL used in Slack message links (optional)
DASHBOARD_URL=

# ---- POLLER (alternative to webhooks) -------------------------
# Set to true to poll HeyReach inbox on a schedule instead of/in addition to webhooks
ENABLE_POLLER=false
POLL_INTERVAL_SECONDS=60
